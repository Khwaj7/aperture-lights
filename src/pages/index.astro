---
import Counter from "../components/Counter";
import ThemeLampToggle from "../components/ThemeLampToggle";
import LampGallery from "../components/LampGallery.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<html lang="en">

<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" href="/favicon.ico" />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<title>Aperture</title>
</head>

<body>
	<BaseLayout title="Lampes artisanales">
		<header class="header glass">
			<div class="brand">
				<h1>Lampes artisanales</h1>
				<p>Glassmorphism • ON = dark + halo • OFF = light</p>
			</div>
			<ThemeLampToggle client:load />
		</header>

		<LampGallery client:load />
	</BaseLayout>
</body>

</html>